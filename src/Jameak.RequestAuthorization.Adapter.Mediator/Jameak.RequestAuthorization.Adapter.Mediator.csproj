<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageTags>authorization auth security cqrs mediator pipeline behavior</PackageTags>
    <PackageDescription>A Mediator.SourceGenerator adapter for Jameak.RequestAuthorization, a strongly-typed request authorization library for mediator-style pipelines.</PackageDescription>
    <PackageVersion>$(PackageVersionAdapterMediator)</PackageVersion>
  </PropertyGroup>
  
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Mediator.Abstractions" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Jameak.RequestAuthorization.Core\Jameak.RequestAuthorization.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../$(PackageReadmeFile)" Pack="true" PackagePath="/" Visible="false" />
  </ItemGroup>

</Project>
