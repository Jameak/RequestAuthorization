      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="MediatR" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Jameak.RequestAuthorization.Adapter.Mediator\Jameak.RequestAuthorization.Adapter.Mediator.csproj" />
    <ProjectReference Include="..\..\src\Jameak.RequestAuthorization.Adapter.AspNetCore\Jameak.RequestAuthorization.Adapter.AspNetCore.csproj" />
    <ProjectReference Include="..\..\src\Jameak.RequestAuthorization.Adapter.MediatR\Jameak.RequestAuthorization.Adapter.MediatR.csproj" />
  </ItemGroup>

</Project>
